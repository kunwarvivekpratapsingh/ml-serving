{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total requests (1h)",
      "type": "stat",
      "targets": [
        { "expr": "sum(increase(prediction_requests_total[1h]))", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg latency (all models)",
      "type": "stat",
      "targets": [
        { "expr": "avg(rate(prediction_latency_seconds_sum[5m]) / rate(prediction_latency_seconds_count[5m])) * 1000", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Error rate",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(prediction_errors_total[5m])) / sum(rate(prediction_requests_total[5m]))", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "title": "Model deployment registry",
      "type": "table",
      "targets": [
        { "expr": "model_deployment_info", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "includeByName": { "model_name": true, "model_version": true, "model_type": true, "scientist": true } } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "title": "Requests per second (by model)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(prediction_requests_total{status=\"success\"}[1m])", "legendFormat": "{{ model_name }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "title": "P95 latency (by model)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))", "legendFormat": "{{ model_name }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] } }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "id": 7,
      "title": "Container CPU usage",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name=~\"ml-serving-project.*\"}[1m]) * 100", "legendFormat": "{{ name }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 104857600 }, { "color": "red", "value": 157286400 }] } }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 8,
      "title": "Container memory usage",
      "type": "timeseries",
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~\"ml-serving-project.*\"}", "legendFormat": "{{ name }}", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ml", "serving", "models"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ML Model Serving Dashboard",
  "uid": "ml-serving-dashboard"
}
